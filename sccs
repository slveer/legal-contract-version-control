#!/usr/bin/env python3 
import sys
import subprocess
import os

command = sys.argv[1] if len(sys.argv) > 1 else None

script_directory = os.path.dirname(os.path.realpath(__file__))
if command == "init":
    sys.exit(subprocess.run(["python3", os.path.join(script_directory, "init.py")] + sys.argv[1:]).returncode)

elif command == "commit":
    sys.exit(subprocess.run(["python3", os.path.join(script_directory, "commit.py")] + sys.argv[1:]).returncode)

else: 
    print(f"Unknown command: {command}")
    print("Invalid command. Please use either 'init' or 'commit', along with required arguments.")
    sys.exit(1)

