#!/usr/bin/env python3 
import sys
import subprocess

command = sys.argv[1] if len(sys.argv) > 1 else None

if command == "init":
    subprocess.run(["python3", "init.py"] + sys.argv[1:]) 

if command == "commit":
    subprocess.run(["python3", "commit.py"] + sys.argv[1:])
    
